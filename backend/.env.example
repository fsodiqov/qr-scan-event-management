PORT=3000
NODE_ENV=development

# MongoDB Atlas (local Docker o'rniga)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/qr-event-management?appName=Cluster0

JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Seed credentials (npm run seed / npm run seed:reset)
# Passwords must meet policy: 12+ chars, upper, lower, number, special
# SEED_SUPER_ADMIN_LOGIN=superadmin
# SEED_SUPER_ADMIN_PASSWORD=Superadmin123!
# SEED_OWNER_LOGIN=owner
# SEED_OWNER_PASSWORD=Owner123456!
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_PASSWORD=Admin123456!
# SEED_OPERATOR_LOGIN=operator
# SEED_OPERATOR_PASSWORD=Operator123!
# Legacy fallback: SEED_*_EMAIL env vars still work as login aliases

# Production (Cloud Run):
# NODE_ENV=production
# CORS_ORIGIN=https://your-app.vercel.app
# APP_URL=https://your-app.vercel.app
