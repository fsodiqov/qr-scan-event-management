PORT=3000
NODE_ENV=development

# MongoDB Atlas (local Docker o'rniga)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/qr-event-management?appName=Cluster0

JWT_SECRET=change-me-to-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Seed credentials (npm run seed / npm run seed:reset)
# SEED_SUPER_ADMIN_LOGIN=superadmin
# SEED_SUPER_ADMIN_PASSWORD=superadmin123456
# SEED_OWNER_LOGIN=owner
# SEED_OWNER_PASSWORD=owner123456
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_PASSWORD=admin123456
# SEED_OPERATOR_LOGIN=operator
# SEED_OPERATOR_PASSWORD=operator123456
# Legacy fallback: SEED_*_EMAIL env vars still work as login aliases

# Production (Cloud Run):
# NODE_ENV=production
# CORS_ORIGIN=https://your-app.vercel.app
# APP_URL=https://your-app.vercel.app
